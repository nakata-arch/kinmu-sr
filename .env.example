# Copy to .env.local and fill in real values. .env.local is gitignored.

# --- Supabase (kinmu-sr-dev) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx
NEXT_PUBLIC_BRAND_NAME=ノース社労士
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Server-only (never commit, never expose to client bundles) ---
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxx

# Personal Access Token for Supabase CLI / Management API.
# Generate at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxx
